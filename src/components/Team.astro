---
import Wrapper from "./Wrapper.astro";
import MemberCard from "./MemberCard.astro";
import teamData from "../data/team.json";

interface Props {
  locale?: string;
}

const { locale = "es" } = Astro.props;
const isEs = locale === "es";
const data = isEs ? teamData.es : teamData.en;
---

<section id="team" class="py-24 bg-black relative overflow-hidden">
  {/* Background accents */}
  <div
    class="absolute top-1/4 -right-64 w-96 h-96 bg-primary-500/5 blur-[120px] rounded-full"
  >
  </div>
  <div
    class="absolute bottom-1/4 -left-64 w-96 h-96 bg-orange-500/5 blur-[120px] rounded-full"
  >
  </div>

  <Wrapper>
    <div class="text-center mb-24">
      <div class="text-overline justify-center">
        <div class="w-12 h-[2px] bg-primary-500"></div>
        {data.subtitle}
        <div class="w-12 h-[2px] bg-primary-500"></div>
      </div>
      <h2 class="title-section">{data.leadership.name}</h2>
    </div>

    <div class="space-y-32">
      {/* Tier 1: Leadership Grid */}
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-16 animate-fade-in"
      >
        {
          data.leadership.members.map((member) => (
            <MemberCard
              member={member}
              locale={locale}
              variant="vertical"
              halo="primary"
            />
          ))
        }
      </div>

      {/* Tier 2: Unified Area Coordinations (Single Grid per Area) */}


        {
          data.coordinations.map((coord) => (
            <div class="animate-fade-in">
              {/* Area Header */}
              <div class="flex items-center gap-6 mb-16">
                <h4 class="text-lg md:text-xl font-bold text-primary-400 uppercase tracking-widest whitespace-nowrap">
                  {coord.name}
                </h4>
                <div class="h-px w-full bg-linear-to-r from-primary-500/30 to-transparent" />
              </div>

              {/* Combined Grid (Coordinator + Support) */}
              <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-x-10 gap-y-16 items-start">
                {/* 1. Main Coordinator (Orange Halo) */}
                <MemberCard
                  member={coord.coordinator}
                  locale={locale}
                  variant="vertical"
                  halo="gold"
                  size="small"
                />

                {/* 2. Support Members (White Halo) */}
                {coord.support.map((member) => (
                  <MemberCard
                    member={member}
                    locale={locale}
                    variant="vertical"
                    halo="gold"
                    size="small"
                  />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
