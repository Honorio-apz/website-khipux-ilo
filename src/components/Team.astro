---
import Wrapper from "./Wrapper.astro";
import MemberCard from "./MemberCard.astro";
import teamData from "../data/team.json";

interface Props {
  locale?: string;
}

const { locale = "es" } = Astro.props;
const isEs = locale === "es";
const data = isEs ? teamData.es : teamData.en;
---

<section id="team" class="py-24 bg-black relative overflow-hidden">
  {/* Background accents */}
  <div
    class="absolute top-1/4 -right-64 w-96 h-96 bg-primary-500/5 blur-[120px] rounded-full"
  >
  </div>
  <div
    class="absolute bottom-1/4 -left-64 w-96 h-96 bg-orange-500/5 blur-[120px] rounded-full"
  >
  </div>

  <Wrapper>
    <div class="text-center mb-24">
      <div class="text-overline justify-center">
        <div class="w-12 h-[2px] bg-primary-500"></div>
        {data.subtitle}
        <div class="w-12 h-[2px] bg-primary-500"></div>
      </div>
      <h2 class="title-section">{data.leadership.name}</h2>
    </div>

    <div class="space-y-32">
      {/* Tier 1: Leadership Grid */}
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-10 gap-y-16 animate-fade-in"
      >
        {
          data.leadership.members.map((member) => (
            <MemberCard
              member={member}
              locale={locale}
              variant="vertical"
              halo="primary"
              size="small"
            />
          ))
        }
      </div>

      {/* Tier 2: Area Coordinators */}
      <div class="space-y-12">
        <div class="text-center mb-16">
          <h3
            class="text-2xl md:text-3xl font-bold text-white uppercase tracking-tight"
          >
            {data.coordinators.name}
          </h3>
          <div class="h-1 w-20 bg-primary-500 mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-10 gap-y-16 animate-fade-in items-start">
          {
            data.coordinators.members.map((member) => (
              <MemberCard
                member={member}
                locale={locale}
                variant="vertical"
                halo="gold"
                size="small"
              />
            ))
          }
        </div>
      </div>

      {/* Tier 3: Support Staff */}
      <div class="space-y-12 pt-16">
        <div class="text-center mb-16">
          <h3
            class="text-2xl md:text-3xl font-bold text-white uppercase tracking-tight"
          >
            {data.support.name}
          </h3>
          <div class="h-1 w-20 bg-primary-500 mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="flex flex-wrap justify-center gap-x-12 gap-y-12 max-w-4xl mx-auto animate-fade-in">
          {
            data.support.members.map((member) => (
              <div class="text-center group">
                {member.linkedin ? (
                  <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform hover:-translate-y-0.5">
                    <h4 class="text-lg font-bold text-white uppercase group-hover:text-primary-400 transition-colors">{member.name}</h4>
                  </a>
                ) : (
                  <h4 class="text-lg font-bold text-white uppercase">{member.name}</h4>
                )}
                <p class="text-[10px] md:text-xs text-primary-500 uppercase tracking-widest mt-2 font-bold">{member.role}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
