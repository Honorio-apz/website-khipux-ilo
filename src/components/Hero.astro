---
import Wrapper from "./Wrapper.astro";
import heroData from "../data/hero.json";
import siteData from "../data/site.json";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const content = heroData[locale as keyof typeof heroData];
const isEs = locale === "es";

const backgroundSymbols = [
  "/images/patterns/symbol1.svg",
  "/images/patterns/symbol2.svg",
  "/images/patterns/symbol1.svg",
  "/images/patterns/symbol2.svg",
];
const slides = [
  "/slides/11.png",
  "/slides/2.jpeg",
  "/slides/3.jpeg",
  "/slides/5.jpeg",
  "/slides/01.jpg.jpeg",
  "/slides/04.jpg.jpeg",
  "/slides/10.jpg.jpeg",
];
---

<section
  class="relative min-h-dvh flex items-center justify-center bg-black overflow-hidden pt-28 pb-12"
>
  <!-- Background Carousel -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    {
      slides.map((slide, index) => (
        <div
          class={`absolute inset-0 bg-cover bg-center transition-opacity duration-[6000ms] ease-in-out hero-slide ${
            index === 0 ? "opacity-100 active" : "opacity-0"
          }`}
          style={`background-image: url('${slide}'); z-index: ${slides.length - index};`}
        />
      ))
    }
  </div>

  <!-- Main Background Overlay (Darker) -->
  <div
    class="absolute inset-0 bg-linear-to-b from-black/80 via-black/40 to-black z-1 pointer-events-none"
  >
  </div>

  <!-- Content Contrast Overlay (Radial) -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,0,0,0.6)_0%,transparent_50%)] z-1 pointer-events-none"
  >
  </div>

  <!-- Decorative Mesh Glows -->
  <div
    class="absolute -top-1/4 -left-1/4 w-[60vw] h-[60vw] bg-primary-500/10 rounded-full blur-[120px] pointer-events-none"
  >
  </div>
  <div
    class="absolute -bottom-1/4 -right-1/4 w-[50vw] h-[50vw] bg-primary-600/5 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <Wrapper
    class="relative z-10 w-full h-full flex flex-col items-center justify-center text-center"
  >
    <div
      class="max-w-5xl mx-auto space-y-6 md:space-y-10 flex flex-col items-center hero-content-fade-in"
    >
      <!-- Brand Pill -->
      <div
        class="inline-flex items-center gap-2 p-1 px-4 rounded-full bg-black/40 border border-white/10 backdrop-blur-md shadow-2xl"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-primary-500 animate-pulse"
        ></span>
        <span
          class="text-[0.6rem] md:text-[0.7rem] uppercase tracking-[0.25em] font-black text-white/90"
        >
          {content.event_type}
        </span>
      </div>

      <!-- Main Logo / Title -->
      <div class="relative group mb-12">
        <div
          class="flex items-center justify-center gap-2 sm:gap-4 flex-nowrap text-3xl md:text-6xl font-semibold"
        >
          <img
            src="/brand/khipux ilo transparent.png"
            alt="KHIPUx Logo"
            class="h-14 sm:h-16 md:h-20 lg:h-24 w-auto -bottom-1 object-contain drop-shadow-[0_4px_25px_rgba(0,0,0,0.9)]"
          />
        </div>
        <div
          class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-20 h-0.5 bg-linear-to-r from-transparent via-primary-500 to-transparent opacity-60"
        >
        </div>
      </div>

      <!-- Tagline / Description -->
      <p
        class="text-body max-w-2xl mx-auto px-4 text-white/80! drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)]"
      >
        {content.description}
      </p>

      <!-- Event Details & Actions Row -->
      <div class="w-full space-y-6 md:space-y-8">
        <div class="flex flex-wrap justify-center gap-6 md:gap-10">
          <!-- Date -->
          <div class="flex items-center gap-3 group">
            <div
              class="p-2 rounded-xl bg-white/5 border border-white/10 group-hover:border-primary-500/30 transition-colors"
            >
              <svg
                class="w-4 h-4 text-primary-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <span class="text-xs md:text-sm font-semibold text-white/90"
              >{isEs ? "17-18 Agosto, 2026" : "Aug 17-18, 2026"}</span
            >
          </div>
          <!-- Location -->
          <div class="flex items-center gap-3 group">
            <div
              class="p-2 rounded-xl bg-white/5 border border-white/10 group-hover:border-primary-500/30 transition-colors"
            >
              <svg
                class="w-4 h-4 text-primary-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <span class="text-xs md:text-sm font-semibold text-white/90"
              >{isEs ? "Ilo, Perú" : "Ilo, Peru"}</span
            >
          </div>
        </div>

        <!-- Call to Actions -->
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-5 px-4 mb-8"
        >
          <a
            href={isEs ? "/es/register" : "/en/register"}
            class="relative px-10 py-4 bg-primary-500 text-white rounded-full font-bold text-lg transition-all duration-300 shadow-[0_10px_30px_rgba(241,91,36,0.3)] hover:shadow-[0_15px_40px_rgba(241,91,36,0.5)] hover:scale-105 active:scale-95 w-full sm:w-auto overflow-hidden group/btn text-center"
          >
            <div
              class="absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-white/20 to-transparent group-hover/btn:translate-x-full transition-transform duration-700"
            >
            </div>
            <span class="relative z-10 flex items-center gap-2">
              {content.cta_primary}
              <svg
                class="w-5 h-5 transition-transform group-hover/btn:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </span>
          </a>
          <a
            href={isEs ? "/es/schedule" : "/en/schedule"}
            class="px-10 py-4 bg-white/5 border border-white/10 backdrop-blur-md text-white rounded-full font-bold text-lg transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:scale-105 w-full sm:w-auto text-center"
          >
            <span class="flex items-center justify-center gap-2">
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
              {isEs ? "Ver Programa" : "View Program"}
            </span>
          </a>
        </div>

        <!-- Scholarship Notice -->
        <!-- <div class="max-w-2xl mx-auto px-4 mb-10 animate-fade-in delay-700">
          <div class="bg-primary-500/10 border border-primary-500/20 backdrop-blur-sm rounded-2xl p-4 md:p-6 text-center">
            <p class="text-white/90 text-sm md:text-base leading-relaxed">
              <span class="text-primary-500 font-bold uppercase tracking-widest text-xs block mb-2">{isEs ? "Próximamente" : "Coming Soon"}</span>
              {isEs 
                ? "Se está trabajando en becas para la gestión de alumnos y ex-alumnos. ¡Atentos a nuestras redes sociales!" 
                : "We are currently working on scholarships for students and alumni. Stay tuned to our social media for updates!"}
            </p>
          </div>
        </div> -->
      </div>

      <!-- Stats Floating Cards -->
      <div class="pt-4 w-full">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-6">
          {
            content.stats.map(
              (stat: { value: string; label: string }, index: number) => (
                <div
                  class="stat-card flex flex-col items-center justify-center p-4 md:p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-xl shadow-2xl transition-all duration-500 hover:bg-white/10 hover:-translate-y-1 group"
                  style={`animation-delay: ${index * 0.1}s`}
                >
                  <div class="text-2xl md:text-3xl font-black text-white mb-0.5 group-hover:text-primary-400 transition-colors font-heading tracking-tight">
                    {stat.value}
                  </div>
                  <div class="text-[0.6rem] md:text-[0.65rem] text-white/50 uppercase tracking-[0.2em] font-bold group-hover:text-white/80 transition-colors">
                    {stat.label}
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>

<style>
  .hero-content-fade-in {
    opacity: 0;
    transform: translateY(30px);
    animation: hero-appear 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes hero-appear {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .stat-card {
    opacity: 0;
    transform: translateY(20px);
    animation: card-appear 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes card-appear {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function setupCarousel() {
    const slides = document.querySelectorAll(".hero-slide");
    if (slides.length <= 1) return;

    // Pick a random starting index
    let currentIndex = Math.floor(Math.random() * slides.length);

    // Reset all slides and set only the random one to active
    slides.forEach((slide, index) => {
      slide.classList.remove("opacity-100", "active");
      slide.classList.add("opacity-0");
      if (index === currentIndex) {
        slide.classList.remove("opacity-0");
        slide.classList.add("opacity-100", "active");
      }
    });

    const interval = 19000; // 12 seconds per slide to allow 9 seconds of smooth fading

    setInterval(() => {
      const currentSlide = slides[currentIndex];
      currentIndex = (currentIndex + 1) % slides.length;
      const nextSlide = slides[currentIndex];

      // Fade out current
      currentSlide.classList.remove("opacity-100", "active");
      currentSlide.classList.add("opacity-0");

      // Fade in next
      nextSlide.classList.remove("opacity-0");
      nextSlide.classList.add("opacity-100", "active");
    }, interval);
  }

  // Initial setup
  setupCarousel();

  // Re-run on View Transitions if enabled
  document.addEventListener("astro:after-swap", setupCarousel);
</script>
