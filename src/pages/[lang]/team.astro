---
import Layout from "../../layouts/Layout.astro";
import teamData from "../../data/team.json";
import MemberCard from "../../components/MemberCard.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const isEs = lang === "es";
const data = isEs ? teamData.es : teamData.en;
---

<Layout
  title={data.title + " - Khipux"}
  lang={lang}
  description={isEs
    ? "Conoce al equipo organizador de KHIPUx Ilo 2026."
    : "Meet the organizing team of KHIPUx Ilo 2026."}
>
  <section class="pt-32 pb-24 bg-black min-h-screen relative overflow-hidden">
    {/* Background accents */}
    <div
      class="absolute top-1/4 -right-64 w-96 h-96 bg-primary-500/5 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-1/4 -left-64 w-96 h-96 bg-orange-500/5 blur-[120px] rounded-full"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-24">
        <div class="text-overline justify-center">
          <div class="w-12 h-[2px] bg-primary-500"></div>
          {data.subtitle}
          <div class="w-12 h-[2px] bg-primary-500/120"></div>
        </div>
        <h1 class="title-section">{data.leadership.name}</h1>
      </div>

      <div class="space-y-32">
        {/* Tier 1: Leadership Grid */}
        <div class="animate-fade-in">
          <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-10 gap-y-16"
          >
            {
              data.leadership.members.map((member) => (
                <MemberCard
                  member={member}
                  locale={lang}
                  variant="vertical"
                  halo="primary"
                  size="small"
                />
              ))
            }
          </div>
        </div>

        {/* Tier 2: Area Coordinators */}
        <div class="space-y-12 mt-24">
          <div class="text-center mb-16">
            <h2
              class="text-2xl md:text-3xl font-bold text-white uppercase tracking-tight"
            >
              {data.coordinators.name}
            </h2>
            <div class="h-1 w-20 bg-primary-500 mx-auto mt-4 rounded-full"></div>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-10 gap-y-16 animate-fade-in items-start">
            {
              data.coordinators.members.map((member) => (
                <MemberCard
                  member={member}
                  locale={lang}
                  variant="vertical"
                  halo="gold"
                  size="small"
                />
              ))
            }
          </div>
        </div>

        {/* Tier 3: Support Staff */}
        <div class="space-y-12 mt-24">
          <div class="text-center mb-16">
            <h2
              class="text-2xl md:text-3xl font-bold text-white uppercase tracking-tight"
            >
              {data.support.name}
            </h2>
            <div class="h-1 w-20 bg-primary-500 mx-auto mt-4 rounded-full"></div>
          </div>

          <div class="flex flex-wrap justify-center gap-x-12 gap-y-12 max-w-4xl mx-auto animate-fade-in">
            {
              data.support.members.map((member) => (
                <div class="text-center group">
                  {member.linkedin ? (
                    <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform hover:-translate-y-0.5">
                      <h3 class="text-lg font-bold text-white uppercase group-hover:text-primary-400 transition-colors">{member.name}</h3>
                    </a>
                  ) : (
                    <h3 class="text-lg font-bold text-white uppercase">{member.name}</h3>
                  )}
                  <p class="text-[10px] md:text-xs text-primary-500 uppercase tracking-widest mt-2 font-bold">{member.role}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
