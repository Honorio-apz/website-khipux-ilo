---
import Layout from "../../layouts/Layout.astro";
import teamData from "../../data/team.json";
import MemberCard from "../../components/MemberCard.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const isEs = lang === "es";
const data = isEs ? teamData.es : teamData.en;
---

<Layout
  title={data.title + " - Khipux"}
  lang={lang}
  description={isEs
    ? "Conoce al equipo organizador de KHIPUx Ilo 2026."
    : "Meet the organizing team of KHIPUx Ilo 2026."}
>
  <section class="pt-32 pb-24 bg-black min-h-screen relative overflow-hidden">
    {/* Background accents */}
    <div
      class="absolute top-1/4 -right-64 w-96 h-96 bg-primary-500/5 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-1/4 -left-64 w-96 h-96 bg-orange-500/5 blur-[120px] rounded-full"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-24">
        <div class="text-overline justify-center">
          <div class="w-12 h-[2px] bg-primary-500"></div>
          {data.subtitle}
          <div class="w-12 h-[2px] bg-primary-500/120"></div>
        </div>
        <h1 class="title-section">{data.leadership.name}</h1>
      </div>

      <div class="space-y-32">
        {/* Tier 1: Leadership Grid */}
        <div class="animate-fade-in">
          <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-16"
          >
            {
              data.leadership.members.map((member) => (
                <MemberCard
                  member={member}
                  locale={lang}
                  variant="vertical"
                  halo="primary"
                />
              ))
            }
          </div>
        </div>

        {/* Tier 2: Unified Area Coordinations (Single Grid per Area) */}
        <div class="space-y-24">
          <div class="text-center mb-16">
            <h2
              class="text-2xl md:text-3xl font-bold text-white uppercase tracking-tight"
            >
              {isEs ? "Coordinadores de Área" : "Area Coordinators"}
            </h2>
            <div class="h-1 w-20 bg-primary-500 mx-auto mt-4 rounded-full">
            </div>
          </div>

          {
            data.coordinations.map((coord) => (
              <div class="animate-fade-in">
                {/* Area Header */}
                <div class="flex items-center gap-6 mb-16">
                  <h3 class="text-lg md:text-xl font-bold text-primary-400 uppercase tracking-widest whitespace-nowrap">
                    {coord.name}
                  </h3>
                  <div class="h-px w-full bg-linear-to-r from-primary-500/30 to-transparent" />
                </div>

                {/* Combined Grid (Coordinator + Support) */}
                <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-x-10 gap-y-16 items-start">
                  {/* Coordinator (Orange Halo) */}
                  <MemberCard
                    member={coord.coordinator}
                    locale={lang}
                    variant="vertical"
                    halo="gold"
                    size="small"
                  />

                  {/* Support Team (White Halo) */}
                  {coord.support.map((member) => (
                    <MemberCard
                      member={member}
                      locale={lang}
                      variant="vertical"
                      halo="gold"
                      size="small"
                    />
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
