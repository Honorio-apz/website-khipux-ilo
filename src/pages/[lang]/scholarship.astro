---
import Layout from "../../layouts/Layout.astro";
import registrationData from "../../data/registration.json";
import Timeline from "../../components/Timeline.astro";
import Wrapper from "../../components/Wrapper.astro";

export function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const isEs = lang === "es";

const content = isEs ? registrationData.es : registrationData.en;
const data = content.scholarship;
---

<Layout
    title={`${data.title} - Khipux`}
    lang={lang}
    description={data.description}
>
    <section class="pt-32 pb-24 bg-black min-h-screen relative overflow-hidden">
        {/* Background Decorative Elements */}
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-500/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-orange-500/5 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/2"></div>

        <Wrapper>
            <div class="max-w-4xl mx-auto">
                {/* Header */}
                <div class="text-center mb-20 animate-fade-in">
                    <div class="inline-flex items-center gap-3 text-primary-500 font-bold mb-6">
                        <div class="w-12 h-[2px] bg-primary-500"></div>
                        <span class="uppercase tracking-widest text-xs">{data.subtitle}</span>
                        <div class="w-12 h-[2px] bg-primary-500"></div>
                    </div>
                    <h1 class="text-4xl md:text-6xl font-black text-white font-heading uppercase tracking-tight mb-8">
                        {data.title}
                    </h1>
                    <p class="text-xl text-gray-400 leading-relaxed max-w-2xl mx-auto">
                        {data.description}
                    </p>
                </div>

                {/* Main Content Card */}
                <div class="bg-white/5 border border-white/10 rounded-3xl p-8 md:p-12 mb-20 shadow-2xl backdrop-blur-sm">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                        <div>
                            <h2 class="text-2xl font-bold text-white mb-6 uppercase tracking-tight">
                                {isEs ? "¿Qué incluye la beca?" : "What's included?"}
                            </h2>
                            <ul class="space-y-4">
                                {[
                                    isEs ? "Gastos de transporte (avión/bus)" : "Travel expenses (flight/bus)",
                                    isEs ? "Alojamiento durante el evento" : "Accommodation during the event",
                                    isEs ? "Acceso completo a talleres y charlas" : "Full access to workshops and talks",
                                    isEs ? "Materiales y certificaciones" : "Materials and certifications"
                                ].map(item => (
                                    <li class="flex items-center gap-3 text-gray-300">
                                        <svg class="w-5 h-5 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                        </svg>
                                        <span>{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                        <div class="relative group">
                            <div class="absolute inset-0 bg-primary-500/20 blur-3xl rounded-full scale-75 group-hover:scale-100 transition-transform"></div>
                            <img src="/beca_illus.webp" alt="Scholarship Illustration" class="relative z-10 w-full h-auto drop-shadow-2xl grayscale group-hover:grayscale-0 transition-all duration-700" />
                        </div>
                    </div>
                </div>

                {/* Timeline Section */}
                <div class="mb-24 px-4">
                    <Timeline items={data.timeline} title={data.timeline_title} />
                </div>

                {/* CTA Section */}
                <div class="text-center">
                    <div class="inline-block p-[2px] rounded-full bg-linear-to-r from-primary-500 via-orange-400 to-primary-600 shadow-[0_0_50px_rgba(241,91,36,0.3)] hover:shadow-[0_0_80px_rgba(241,91,36,0.5)] transition-all duration-500 hover:scale-105">
                        <a
                            href={data.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="block px-12 py-6 bg-black rounded-full font-bold text-xl md:text-2xl text-white hover:bg-white hover:text-black transition-all duration-300 uppercase tracking-widest text-center"
                        >
                            {data.cta}
                        </a>
                    </div>
                    <p class="mt-6 text-sm text-gray-500 uppercase tracking-widest">
                        {isEs ? "Los formularios se abrirán en la fecha indicada arriba" : "Forms will open on the date listed above"}
                    </p>
                </div>
            </div>
        </Wrapper>
    </section>
</Layout>
